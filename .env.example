# connection_limit=10 assumes the Supabase Transaction pooler (not Session pooler)
# and a plan that allows it. On the free-tier Session pooler this will hit
# EMAXCONNSESSION errors — drop it back to 1 there, or upgrade/switch pooler mode.
# DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres?connection_limit=10&pool_timeout=20"
# DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres?connection_limit=10&pool_timeout=20"

# # If your network supports IPv6, you can use Supabase's direct host for DIRECT_URL instead:
# # DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# # Optional: only needed when we later add Supabase Auth/Storage client features.
# NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
